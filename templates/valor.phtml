    <script src="<?= URL_ROOT ?>/assets/js/jquery-3.6.0.min.js"></script>
    <script>
        (function() {
			const $apiUrl = '<?= URL_API ?>';
			const redirectTarget = 'https://kapital.com/';
			const redirectFlagKey = 'enc_valor_qr_votado';

            var visitorInput = document.getElementById('visitor-number');
            var stepVisitor = document.getElementById('step-visitor');
            var stepValue = document.getElementById('step-value');
            var stepThanks = document.getElementById('step-thanks');
            var btnContinue = document.getElementById('btn-continue');
            var btnVote = document.getElementById('btn-vote');
            var containerExiste = document.getElementById('containerExiste');

            function goToFinalUrl() {
                window.location.replace(redirectTarget);
            }

            window.addEventListener('pageshow', function(event) {
                var navEntries = performance.getEntriesByType('navigation');
                var isBackForward = event.persisted || (navEntries.length > 0 && navEntries[0].type === 'back_forward');
                if(sessionStorage.getItem(redirectFlagKey) === '1' && isBackForward) {
                    goToFinalUrl();
                }
            });

            visitorInput.addEventListener('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '');
            });

            btnContinue.addEventListener('click', function() {
                if(visitorInput.value.trim() === '') {
                    visitorInput.focus();
                    return;
                }

                let invitado_id = visitorInput.value.trim();
                $.get(`${$apiUrl}pregunta/getRegistro/${invitado_id}`, function(resp){
                    stepVisitor.classList.add('hidden');
                    stepValue.classList.remove('hidden');

                    if(resp.response) {
                        containerExiste.classList.remove('hidden');
                        $('#btn-vote').hide();
                        return;
                    }

                    containerExiste.classList.add('hidden');
                    $('#btn-vote').show();
                }, 'json');
            });

            btnVote.addEventListener('click', function() {
                let invitado_id = visitorInput.value.trim();
                $.post(`${$apiUrl}respuesta/addResp/`, { enc_valor_qr_id: <?= $valorId ?>, invitado_id: invitado_id }, function(resp){
                    stepValue.classList.add('hidden');
                    stepThanks.classList.remove('hidden');

                    sessionStorage.setItem(redirectFlagKey, '1');

                    setTimeout(function() {
                        goToFinalUrl();
                    }, 4000);
                }, 'json');
            });
        })();
    </script>
</body>
</html>
