	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
	<script>
		$(function() {
			$apiUrl = '<?= URL_API ?>';

			blockPage();
			$.get($apiUrl + 'reporte/dashboard', function(data) {
				$.unblockUI();
				if (!data.response) {
					swal({ type: 'warning', title: 'Oops!', text: data.message, timer: 4000 });
					return;
				}

				var s = data.result.stats;
				$('#kpi-encuestas-activas').text(s.encuestas_activas);
				$('#kpi-total-preguntas').text(s.total_preguntas);
				$('#kpi-total-intentos').text(s.total_intentos);
				$('#kpi-tiempo-promedio').text(s.tiempo_promedio_min + ' min');

				// Chart: intentos por mes
				var meses   = data.result.intentos_mes.map(function(m) { return m.etiqueta; });
				var totales = data.result.intentos_mes.map(function(m) { return parseInt(m.total); });
				new Chart(document.getElementById('chart-intentos-mes'), {
					type: 'bar',
					data: {
						labels: meses,
						datasets: [{
							label: 'Respuestas',
							data: totales,
							backgroundColor: 'rgba(54, 162, 235, 0.7)',
							borderColor: 'rgba(54, 162, 235, 1)',
							borderWidth: 1
						}]
					},
					options: {
						responsive: true,
						plugins: { legend: { display: false } },
						scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
					}
				});

				// Chart: tipos de pregunta
				var tiposLabels  = data.result.distrib_tipos.map(function(t) { return t.tipo_label; });
				var tiposTotales = data.result.distrib_tipos.map(function(t) { return parseInt(t.total); });
				new Chart(document.getElementById('chart-tipos'), {
					type: 'doughnut',
					data: {
						labels: tiposLabels,
						datasets: [{
							data: tiposTotales,
							backgroundColor: [
								'rgba(255, 99, 132, 0.7)',
								'rgba(54, 162, 235, 0.7)',
								'rgba(255, 205, 86, 0.7)'
							],
							borderWidth: 1
						}]
					},
					options: {
						responsive: true,
						plugins: { legend: { position: 'bottom' } }
					}
				});

				// Top encuestas table
				var tbody = $('#tbody-top-encuestas');
				tbody.empty();
				if (data.result.top_encuestas.length === 0) {
					tbody.append('<tr><td colspan="3" class="text-center text-muted">Sin datos aún</td></tr>');
				} else {
					$.each(data.result.top_encuestas, function(i, e) {
						var id    = String(e.ID_encuesta);
						var folio = 'E-' + (id.length < 3 ? id.padStart(3, '0') : id);
						tbody.append(
							'<tr>' +
							'<td class="text-center"><small>' + folio + '</small></td>' +
							'<td class="text-left"><small>' + e.nombre.toUpperCase() + '</small></td>' +
							'<td class="text-center"><small><strong>' + e.total_intentos + '</strong></small></td>' +
							'</tr>'
						);
					});
				}
			}, 'json');
		});
	</script>
