	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
	<script>
		$(function() {
			$apiUrl = '<?= URL_API ?>';
			var charts = [];

			function escapeHtml(value) {
				return $('<div>').text(value === null || value === undefined ? '' : value).html();
			}

			function renderMetricCard(label, value, accentClass) {
				return '' +
					'<div class="col-md-3 col-sm-6 mb-2">' +
						'<div class="border rounded p-2 h-100 ' + accentClass + '">' +
							'<small class="d-block text-muted">' + label + '</small>' +
							'<strong style="font-size:1.1rem;">' + value + '</strong>' +
						'</div>' +
					'</div>';
			}

			// Cargar encuestas activas en el selector
			$.get($apiUrl + 'encuesta/getAll/0/0/_/1', function(data) {
				if (data.response && data.result.length > 0) {
					$.each(data.result, function(i, e) {
						var id    = String(e.ID_encuesta);
						var folio = 'E-' + (id.length < 3 ? id.padStart(3, '0') : id);
						$('#res-encuesta').append(
							'<option value="' + e.ID_encuesta + '">[' + folio + '] ' + e.nombre.toUpperCase() + '</option>'
						);
					});
				}
			}, 'json');

			$('#btnConsultar').click(function() {
				var id = $('#res-encuesta').val();
				if (!id || id == '0') {
					swal({ type: 'warning', title: 'Oops!', text: 'Selecciona una encuesta', timer: 3000 });
					return;
				}

				var desde = $.trim($('#res-desde').val());
				var hasta = $.trim($('#res-hasta').val());

				if (desde && hasta && desde > hasta) {
					swal({ type: 'warning', title: 'Oops!', text: 'La fecha desde no puede ser mayor a la fecha hasta', timer: 3000 });
					return;
				}

				// Destruir gráficas anteriores
				$.each(charts, function(i, c) { try { c.destroy(); } catch(e) {} });
				charts = [];
				$('#resultados-container').hide();
				$('#sin-datos').hide();

				blockPage();
				var urlApi = $apiUrl + 'reporte/resultados/' + id;
				var qs = [];
				if (desde) qs.push('desde=' + encodeURIComponent(desde));
				if (hasta) qs.push('hasta=' + encodeURIComponent(hasta));
				if (qs.length > 0) urlApi += '?' + qs.join('&');

				$.get(urlApi, function(data) {
					$.unblockUI();
					if (!data.response) {
						swal({ type: 'warning', title: 'Oops!', text: data.message, timer: 4000 });
						return;
					}

					var r = data.result;
					if (r.total_intentos === 0) {
						$('#sin-datos').show();
						return;
					}

					$('#res-nombre-encuesta').text(r.encuesta.nombre.toUpperCase());
					$('#res-total-intentos').text(r.total_intentos + ' respuesta(s) recibida(s)');
					$('#res-total-preguntas').text(r.resumen.total_preguntas);
					$('#res-preguntas-con-respuesta').text(r.resumen.preguntas_con_respuesta);
					$('#res-cobertura-promedio').text(r.resumen.cobertura_promedio + '%');

					var container = $('#preguntas-resultados');
					container.empty();

					$.each(r.preguntas, function(i, pregunta) {
						var chartId   = 'chart-preg-' + pregunta.ID_pregunta;
						var badgeHtml = '';
						if (pregunta.tipo == 1)      badgeHtml = '<span class="badge badge-secondary mr-1">Abierta</span>';
						else if (pregunta.tipo == 2) badgeHtml = '<span class="badge badge-info mr-1">Opción múltiple</span>';
					else if (pregunta.tipo == 4) badgeHtml = '<span class="badge badge-danger mr-1">Postulación</span>';
						var header   = $('<div class="card-header py-2"><h6 class="mb-0">' + badgeHtml + pregunta.pregunta + '</h6></div>');
						var cardBody = $('<div class="card-body"></div>');
						card.append(header).append(cardBody);
						container.append(card);

						var resumenPregunta = $('<div class="row mb-3"></div>');
						resumenPregunta.append(renderMetricCard('Respondieron', pregunta.total_respuestas, 'bg-light'));
						resumenPregunta.append(renderMetricCard('Sin respuesta', pregunta.sin_respuesta, 'bg-light'));
						resumenPregunta.append(renderMetricCard('Cobertura', pregunta.porcentaje_cobertura + '%', 'bg-light'));
						resumenPregunta.append(renderMetricCard('Respuestas únicas', pregunta.respuestas_unicas, 'bg-light'));
						cardBody.append(resumenPregunta);

						if (pregunta.respuesta_top) {
							cardBody.append(
								'<div class="alert alert-secondary py-2 px-3">' +
									'<strong>Respuesta más frecuente:</strong> ' + escapeHtml(pregunta.respuesta_top.valor) +
									' <span class="badge badge-dark ml-1">' + pregunta.respuesta_top.total + '</span>' +
								'</div>'
							);
						}

						if (pregunta.total_respuestas === 0) {
							cardBody.append('<div class="alert alert-warning mb-0">Esta pregunta no recibió respuestas en el período seleccionado.</div>');
							return;
						}

						if (pregunta.tipo == 1 || pregunta.tipo == 4) {
							// Pregunta abierta: tabla de respuestas
							cardBody.append(
								'<p class="text-muted mb-2">Se muestran las respuestas capturadas y su frecuencia. Esto permite detectar patrones repetidos incluso en preguntas abiertas.</p>'
							);
							var tbl = $(
								'<table class="table table-sm table-hover table-striped">' +
								'<thead><tr>' +
								'<th class="text-left">Respuesta</th>' +
								'<th class="text-center" style="width:80px">Cantidad</th>' +
								'<th class="text-center" style="width:80px">%</th>' +
								'</tr></thead>' +
								'</table>'
							);
							var tbody = $('<tbody></tbody>');
							$.each(pregunta.respuestas, function(j, resp) {
								var pctAbierta = pregunta.total_respuestas > 0 ? Math.round(resp.total / pregunta.total_respuestas * 100) : 0;
								tbody.append(
									'<tr>' +
									'<td class="text-left"><small>' + escapeHtml(resp.valor) + '</small></td>' +
									'<td class="text-center"><small><strong>' + resp.total + '</strong></small></td>' +
									'<td class="text-center"><small>' + pctAbierta + '%</small></td>' +
									'</tr>'
								);
							});
							tbl.append(tbody);
							cardBody.append($('<div class="table-responsive" style="max-height:260px;overflow-y:auto;"></div>').append(tbl));

						} else {
							// Opción múltiple / Puntuación: gráfica de barras + tabla
							var totalResp = pregunta.total_respuestas;

							// Para tipo puntuación ordenar numéricamente
							var respuestas = pregunta.respuestas.slice();
							if (pregunta.tipo == 3) {
								respuestas.sort(function(a, b) { return parseFloat(a.valor) - parseFloat(b.valor); });
							}

							var labels = respuestas.map(function(r) { return r.valor; });
							var values = respuestas.map(function(r) { return r.total; });

							// Métricas para puntuación
							if (pregunta.tipo == 3) {
								var promedio = pregunta.metricas.promedio !== null ? pregunta.metricas.promedio.toFixed(2) : '—';
								var minimo = pregunta.metricas.minimo !== null ? pregunta.metricas.minimo : '—';
								var maximo = pregunta.metricas.maximo !== null ? pregunta.metricas.maximo : '—';
								var ratingMetrics = $('<div class="row mb-3"></div>');
								ratingMetrics.append(renderMetricCard('Promedio', promedio, 'border-primary'));
								ratingMetrics.append(renderMetricCard('Calificación mínima', minimo, 'border-primary'));
								ratingMetrics.append(renderMetricCard('Calificación máxima', maximo, 'border-primary'));
								ratingMetrics.append(renderMetricCard('Escala', pregunta.escala ? pregunta.escala : '—', 'border-primary'));
								cardBody.append(ratingMetrics);
							}

							var palette = [
								'rgba(54,162,235,0.7)', 'rgba(255,99,132,0.7)',
								'rgba(255,205,86,0.7)', 'rgba(75,192,192,0.7)',
								'rgba(153,102,255,0.7)', 'rgba(255,159,64,0.7)',
								'rgba(199,199,199,0.7)', 'rgba(83,102,255,0.7)',
								'rgba(40,159,64,0.7)',   'rgba(210,99,132,0.7)'
							];
							var colors = labels.map(function(_, idx) { return palette[idx % palette.length]; });

							var row     = $('<div class="row"></div>');
							var colChart = $('<div class="col-md-7 mb-2"></div>');
							var colTable = $('<div class="col-md-5"></div>');

							colChart.append('<canvas id="' + chartId + '" height="160"></canvas>');

							var tbl2 = $(
								'<table class="table table-sm table-hover table-striped">' +
								'<thead><tr>' +
								'<th class="text-left">Opción</th>' +
								'<th class="text-center">Cant.</th>' +
								'<th class="text-center">%</th>' +
								'</tr></thead>' +
								'</table>'
							);
							var tbody2 = $('<tbody></tbody>');
							$.each(respuestas, function(j, resp) {
								var pct = totalResp > 0 ? Math.round(resp.total / totalResp * 100) : 0;
								tbody2.append(
									'<tr>' +
									'<td class="text-left"><small>' + escapeHtml(resp.valor) + '</small></td>' +
									'<td class="text-center"><small>' + resp.total + '</small></td>' +
									'<td class="text-center"><small>' + pct + '%</small></td>' +
									'</tr>'
								);
							});
							tbl2.append(tbody2);
							colTable.append(tbl2);
							row.append(colChart).append(colTable);
							cardBody.append(row);

							// Crear gráfica después de insertar en DOM
							(function(cid, lbl, vals, clrs) {
								setTimeout(function() {
									var ctx = document.getElementById(cid);
									if (!ctx) return;
									var ch = new window.Chart(ctx, {
										type: 'bar',
										data: {
											labels: lbl,
											datasets: [{
												label: 'Respuestas',
												data: vals,
												backgroundColor: clrs,
												borderWidth: 1
											}]
										},
										options: {
											responsive: true,
											plugins: { legend: { display: false } },
											scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
										}
									});
									charts.push(ch);
								}, 80);
							})(chartId, labels, values, colors);
						}
					});

					$('#resultados-container').show();
			}, 'json');
