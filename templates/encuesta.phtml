					}

					function getActiveStackSelection(questionId) {
						var $activeCard = $('.step[data-id="' + questionId + '"] .stack-card.active').first();
						console.log(questionId)
						if(!$activeCard.length) {
							return null;
						}

						var opcionSeleccionada = $.trim($activeCard.data('opcion-id'));
						if(opcionSeleccionada === '') {
							return null;
						}

						var nombreFinalista = $.trim($activeCard.find('.stack-card-title').first().attr('data-txt'));
						return {
							value: opcionSeleccionada,
							label: nombreFinalista !== '' ? nombreFinalista : 'Invitado #' + opcionSeleccionada
						};
					}

					function mostrarError($el, msg) {
						$el.text(msg).show();
						setTimeout(function() { $el.hide(); }, 4000);
					}

					function validarInvitado() {
						const visitorNumber = $.trim($visitorNumber.val());
						$visitorError.hide();
						$visitorDuplicate.hide();

						if(visitorNumber === '') {
							mostrarError($visitorError, 'Ingresa un número de invitado válido.');
							$visitorNumber.focus();
							return;
						}

						$.get($apiUrl + 'intento/exists/' + surveyUrlId + '/' + encodeURIComponent(visitorNumber), function(existsResp) {
							if(existsResp.response) {
								mostrarError($visitorDuplicate, $visitorDuplicate.text());
								return;
							}
							$.post($apiUrl + 'save-enc-invitado/' + surveyCode, { invitado_id: visitorNumber }, function(saveResp) {
								if(!saveResp || !saveResp.response) {
									mostrarError($visitorError, 'No fue posible validar el número. Intenta nuevamente.');
									return;
								}
								invitadoId = visitorNumber;
								mostrarEncuesta();
							}, 'json');
						}, 'json').fail(function() {
							mostrarError($visitorError, 'No fue posible validar el número. Intenta nuevamente.');
						});
					}

					$('#btn-visitor-continue').on('click', validarInvitado);
					$visitorNumber.on('keypress', function(e) {
						if(e.which === 13) { e.preventDefault(); validarInvitado(); }
					});

					if(invitadoId && invitadoId !== '') {
						mostrarEncuesta();
					}

					function generateSummary() {
						const summaryContainer = document.getElementById('summary-container');
						if (!summaryContainer) {
							return;
						}

						summaryContainer.innerHTML = '';

						const preguntas = <?php echo json_encode($url->preguntas); ?>;
						preguntas.forEach((pregunta) => {
							let valor = $(`input[type="radio"][name="question_${pregunta.ID_pregunta}"]:checked`).val();
							let valorResumen = valor;
							if (valor === undefined || valor === '') {
								const $select = $(`select[name="question_${pregunta.ID_pregunta}"]`);
								valor = $select.val();
								if (valor !== undefined && valor !== '') {
									const textoSeleccionado = $select.find('option:selected').text();
									if (textoSeleccionado && textoSeleccionado !== '-- Selecciona una opción --') {
										valorResumen = textoSeleccionado;
									}
								}
							}

							if (valor === undefined || valor === '') {
								valor = $.trim($('textarea[name="question_'+pregunta.ID_pregunta+'"]').val());
								valorResumen = valor;
							}

							if ((valor === undefined || valor === '') && (parseInt(pregunta.tipo, 10) === 5 || parseInt(pregunta.tipo, 10) === 6)) {
								const stackSelection = getActiveStackSelection(pregunta.ID_pregunta);
								if (stackSelection) {
									valor = stackSelection.value;
									valorResumen = stackSelection.label;
								}
							}

							if (valor !== undefined && valor !== '' && valor !== null) {
								const summaryItem = document.createElement('div');
								summaryItem.className = 'summary-item';
							let valorHtml = `<p>${valorResumen}</p>`;
							if (parseInt(pregunta.tipo) === 3 && valor !== '' && valor !== null && valor !== undefined) {
								const n = parseInt(valor);
								const icono = parseInt(pregunta.icono);
								if (!isNaN(n) && n > 0) {
									if (icono === 0) {
										const icons = '&#9733;'.repeat(n);
										valorHtml = `<p style="color:#f6a821;font-size:22px;letter-spacing:2px">${icons} <span style="color:#444;font-size:15px">${n}</span></p>`;
									} else if (icono === 1) {
										const icons = '&#128512;'.repeat(n);
										valorHtml = `<p style="color:#ffb703;font-size:22px;letter-spacing:2px">${icons} <span style="color:#444;font-size:15px">${n}</span></p>`;
									} else if (icono === 2) {
										valorHtml = `<p style="font-size:15px"><span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border:2px solid #2254a5;border-radius:6px;font-weight:700;color:#2254a5">${n}</span></p>`;
									}
								}
							}
							summaryItem.innerHTML = `<h4>${pregunta.pregunta}</h4>${valorHtml}`;
								summaryContainer.appendChild(summaryItem);
							}
						});

						if (!summaryContainer.children.length) {
							summaryContainer.innerHTML = '<div class="summary-item"><p>Aún no hay respuestas para mostrar.</p></div>';
						}
					}

