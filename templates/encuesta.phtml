						if(e.key === 'Enter' || e.key === ' ') {
							e.preventDefault();
							$(this).trigger('click');
						}
					});

					(function initStackSwipe() {
						var threshold = 35;
						var restraintY = 45;

						function getPointFromEvent(event) {
							if(event.originalEvent && event.originalEvent.touches && event.originalEvent.touches.length) {
								return event.originalEvent.touches[0];
							}
							if(event.originalEvent && event.originalEvent.changedTouches && event.originalEvent.changedTouches.length) {
								return event.originalEvent.changedTouches[0];
							}
							return event;
						}

						$(document).on('touchstart mousedown', '.stack-wrapper', function(e) {
							if($(e.target).closest('.arrow').length) {
								$(this).data('swipe-blocked', true);
								return;
							}

							$(this).data('swipe-blocked', false);

							if(e.type === 'mousedown' && e.which !== 1) {
								return;
							}

							var point = getPointFromEvent(e);
							$(this).data('swipe-start-x', point.pageX);
							$(this).data('swipe-start-y', point.pageY);
							$(this).data('swipe-moved', false);
						});

						$(document).on('touchmove mousemove', '.stack-wrapper', function() {
							if($(this).data('swipe-blocked')) {
								return;
							}

							$(this).data('swipe-moved', true);
						});

						$(document).on('touchend mouseup', '.stack-wrapper', function(e) {
							if($(this).data('swipe-blocked')) {
								$(this).data('swipe-blocked', false);
								$(this).removeData('swipe-start-x').removeData('swipe-start-y').removeData('swipe-moved');
								return;
							}

							var startX = parseFloat($(this).data('swipe-start-x'));
							var startY = parseFloat($(this).data('swipe-start-y'));
							var moved = !!$(this).data('swipe-moved');

							if(isNaN(startX) || isNaN(startY) || !moved) {
								return;
							}

							var point = getPointFromEvent(e);
							var diffX = point.pageX - startX;
							var diffY = point.pageY - startY;

							if(Math.abs(diffX) >= threshold && Math.abs(diffY) <= restraintY) {
								if(diffX < 0) {
									moveStackCards($(this), 'next');
								} else {
									moveStackCards($(this), 'prev');
								}
							}
						});
					})();

