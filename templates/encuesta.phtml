					<?php endif; ?>
			});

			function evaluar(element, counter) {
				let val = parseInt(element.value);
				let contenedor = document.getElementById('comentarios_' + counter);
				let textarea = document.getElementById('comentario_' + counter);
				let $textarea = $(textarea);

				if (isNaN(val)) {
					val = -1;
				}

				if (val < 3 && val >= 0) {
					contenedor.style.display = 'block';
					$textarea.addClass('requerido');

					if (!$textarea.data('rules-added')) {
						$textarea.rules('add', {
							required: {
								depends: function () {
									return $(this).is(':visible');
								}
							},
							minlength: {
								param: 10,
								depends: function () {
									return $(this).is(':visible');
								}
							},
							messages: {
								required: "Este campo es requerido.",
								minlength: "Por favor ingrese al menos 10 caracteres."
							}
						});
						$textarea.data('rules-added', true);
					}
				} else {
					contenedor.style.display = 'none';
					$textarea.val('');
					$textarea.removeClass('error');
					$textarea.next('label.error').remove();
				}
			}
