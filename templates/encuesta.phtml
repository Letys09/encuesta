					function applyStackCardClasses($wrapper, activeIndex) {
						var $cards = $wrapper.find('.stack-card');
						var total = $cards.length;

						if(total === 0) {
							return;
						}

						$cards.removeClass('active next prev');

						if(activeIndex < 0) {
							activeIndex = total - 1;
						} else if(activeIndex >= total) {
							activeIndex = 0;
						}

						var nextIndex = (activeIndex + 1) % total;
						var prevIndex = (activeIndex - 1 + total) % total;

						$cards.eq(activeIndex).addClass('active');
						if(total > 1) {
							$cards.eq(nextIndex).addClass('next');
							$cards.eq(prevIndex).addClass('prev');
						}

						$wrapper.data('active-index', activeIndex);
					}

					function moveStackCards($wrapper, direction) {
						var $cards = $wrapper.find('.stack-card');
						if($cards.length <= 1) {
							return;
						}

						var activeIndex = parseInt($wrapper.data('active-index'), 10);
						if(isNaN(activeIndex)) {
							activeIndex = $cards.index($cards.filter('.active').first());
							if(activeIndex < 0) {
								activeIndex = 0;
							}
						}

						activeIndex = direction === 'prev' ? activeIndex - 1 : activeIndex + 1;
						applyStackCardClasses($wrapper, activeIndex);
					}

					$(document).find('.stack-wrapper').each(function() {
						var $wrapper = $(this);
						var $wrapperCards = $wrapper.find('.stack-card');
						var initialIndex = $wrapperCards.index($wrapper.find('.stack-card.active').first());
						if(initialIndex < 0) {
							initialIndex = 0;
						}
						applyStackCardClasses($wrapper, initialIndex);
					});

					$(document).on('click', '.stack-wrapper .arrow', function() {
						var $arrow = $(this);
						var direction = $arrow.data('dir') === 'prev' ? 'prev' : 'next';
						moveStackCards($arrow.closest('.stack-wrapper'), direction);
					});

					$(document).on('click', '.stack-card .stack-vote-btn', function() {
						var $card = $(this).closest('.stack-card');
						var $step = $card.closest('.step.step-typeVoto');
						var $wrapper = $card.closest('.stack-wrapper');

						if(!$step.length || !$wrapper.length) {
