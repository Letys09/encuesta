	<script>
		$(function() {
			var $apiUrl = '<?= URL_API ?>';
			var encuestaId = null;
			var totalResp = 0;
			var encuestaPostulacion = null; // { ID_encuesta, ID_pregunta }
			var votacionStatus = { exists: false, ID_pregunta_votacion: 0 };

			// Cargar encuestas activas
			$.get(`${$apiUrl}encuesta/getAll/0/0/_/1`, function(data) {
				if (data.response && data.result) {
					$.each(data.result, function(i, enc) {
						$('#dsc-encuesta').append(
							$('<option>', { value: enc.ID_encuesta, text: enc.nombre })
						);
					});
					if ($('#dsc-encuesta').hasClass('select2')) {
						$('#dsc-encuesta').select2({ theme: 'bootstrap4', placeholder: '-- Selecciona una encuesta --', allowClear: true });
					}
				}
			});

			function buildQueryString() {
				var desde = $('#dsc-desde').val();
				var hasta = $('#dsc-hasta').val();
				var qs = [];
				if (desde) qs.push('desde=' + encodeURIComponent(desde));
				if (hasta) qs.push('hasta=' + encodeURIComponent(hasta));
				return qs.length > 0 ? '?' + qs.join('&') : '';
			}

			function escapeHtml(text) {
				return $('<div>').text(text === null || text === undefined ? '' : text).html();
			}

			function loadValoresVotesPreview() {
				$('#valores-resumen').hide();
				$('#valores-tabla-wrap').hide();
				$('#valores-sin-datos').hide();
				$('#btnValoresXlsx, #btnValoresPdf').prop('disabled', true);

				var url = $apiUrl + 'reporte/valores-votos' + buildQueryString();
				$.get(url, function(data) {
					if (!data.response || !data.result || !data.result.valores) {
						$('#valores-sin-datos').show();
						return;
					}

					var valores = data.result.valores;
					$('#valores-total-votos').text(data.result.total_votos || 0);
					$('#valores-total-reg').text(data.result.total_valores || 0);

					if (valores.length === 0) {
						$('#valores-sin-datos').show();
						return;
					}

					var rowsHtml = '';
					$.each(valores, function(_, row) {
						rowsHtml += '' +
							'<tr>' +
								'<td>' + escapeHtml(row.codigo) + '</td>' +
								'<td>' + escapeHtml(row.valor) + '</td>' +
								'<td class="text-center"><strong>' + escapeHtml(row.votos) + '</strong></td>' +
								'<td>' + escapeHtml(row.invitados) + '</td>' +
							'</tr>';
					});

					$('#valores-tabla-body').html(rowsHtml);
					$('#valores-resumen').show();
					$('#valores-tabla-wrap').show();
					$('#btnValoresXlsx, #btnValoresPdf').prop('disabled', false);
				}).fail(function() {
					swal('Error', 'No fue posible obtener votos por valor.', 'error');
				});
			}

			$('#btnPreview').on('click', function() {
				encuestaId = $('#dsc-encuesta').val();
				if (!encuestaId) {
					swal('Aviso', 'Selecciona una encuesta.', 'warning');
					return;
				}

				$('#dsc-resumen').hide();
				$('#dsc-sin-datos').hide();
				$('#btnDescXlsx, #btnDescPdf').prop('disabled', true);

				var desde = $('#dsc-desde').val();
				var hasta = $('#dsc-hasta').val();
				var qs = [];
				if (desde) qs.push('desde=' + encodeURIComponent(desde));
				if (hasta) qs.push('hasta=' + encodeURIComponent(hasta));
				var url = `${$apiUrl}reporte/resultados/` + encuestaId + (qs.length ? '?' + qs.join('&') : '');

				$.get(url, function(data) {
					if (!data.response || !data.result) {
						$('#dsc-sin-datos').show();
						return;
					}

					var res = data.result;
					totalResp = res.total_intentos || 0;

					if (totalResp === 0) {
						$('#dsc-sin-datos').show();
						return;
					}

					$('#dsc-nombre-encuesta').text(res.encuesta.nombre);
					$('#dsc-total-resp').text(totalResp);
					$('#dsc-total-preg').text(res.resumen.total_preguntas);

					if (res.tiene_postulacion && res.preguntas_postulacion && res.preguntas_postulacion.length > 0) {
						encuestaPostulacion = { ID_encuesta: res.encuesta.ID_encuesta, ID_pregunta: res.preguntas_postulacion[0].ID_pregunta };
						$('#btnDefinirFinalistas').show();
					} else {
						encuestaPostulacion = null;
						$('#btnDefinirFinalistas').hide();
					}

					var periodoTxt = '';
					if (desde || hasta) {
						periodoTxt = 'Del ' + (desde ? desde : '-') + ' al ' + (hasta ? hasta : '-');
					} else {
						periodoTxt = 'Todas las fechas';
					}
					$('#dsc-periodo').text(periodoTxt);

					$('#btnDescXlsx, #btnDescPdf').prop('disabled', false);
					$('#dsc-resumen').show();
				}).fail(function() {
					swal('Error', 'No fue posible obtener los datos.', 'error');
				});
			});

			$('#btnDescXlsx').on('click', function() {
				if (!encuestaId) return;
				var url = `${$apiUrl}reporte/export/xlsx/` + encuestaId + buildQueryString();
				window.location.href = url;
			});

			$('#btnDescPdf').on('click', function() {
				if (!encuestaId) return;
				var url = `${$apiUrl}reporte/export/pdf/` + encuestaId + buildQueryString();
				window.open(url, '_blank');
			});

			$('#btnValoresPreview').on('click', function() {
				loadValoresVotesPreview();
			});

			$('#btnValoresXlsx').on('click', function() {
				var url = `${$apiUrl}reporte/valores-votos/export/xlsx` + buildQueryString();
				window.location.href = url;
			});

			$('#btnValoresPdf').on('click', function() {
				var url = `${$apiUrl}reporte/valores-votos/export/pdf` + buildQueryString();
				window.open(url, '_blank');
			});

			$('#btnDefinirFinalistas').on('click', function() {
				if (!encuestaPostulacion) return;
				$('#finalistas-ID_encuesta').val(encuestaPostulacion.ID_encuesta);
				$('#finalistas-ID_pregunta').val(encuestaPostulacion.ID_pregunta);
				loadVotingStatus(encuestaPostulacion.ID_encuesta, encuestaPostulacion.ID_pregunta, function() {
					loadPostulados(encuestaPostulacion.ID_encuesta, encuestaPostulacion.ID_pregunta);
				});
			});

			function loadVotingStatus(idEncuesta, idPregunta, done) {
				$.get($apiUrl + 'reporte/finalistas/votacion-status/' + idEncuesta + '/' + idPregunta, function(resp) {
					if (resp.response && resp.result) {
						votacionStatus.exists = !!resp.result.exists;
						votacionStatus.ID_pregunta_votacion = resp.result.ID_pregunta_votacion ? parseInt(resp.result.ID_pregunta_votacion, 10) : 0;
					} else {
						votacionStatus = { exists: false, ID_pregunta_votacion: 0 };
					}
				}).always(function() {
					if (typeof done === 'function') done();
				});
			}

			function updateFinalistasCounter() {
				var checked = $('#finalistas-lista input[type="checkbox"]:checked').length;
				$('#finalistas-counter').text(checked + ' / 10 seleccionados');
			}

			function loadPostulados(idEncuesta, idPregunta) {
				blockPage();
				$.get($apiUrl + 'reporte/postulados/' + idEncuesta + '/' + idPregunta, function(resp) {
					var lista = $('#finalistas-lista');
					lista.empty();
					$('#finalistas-empty').hide();
					if (votacionStatus.exists) {
						var txtFolio = votacionStatus.ID_pregunta_votacion > 0 ? 'P-' + String(votacionStatus.ID_pregunta_votacion).padStart(3, '0') : '';
						$('#finalistas-votacion-status').text('Ya existe una pregunta de votación ' + txtFolio + '. Al guardar, solo se actualizará la lista de finalistas.').show();
					} else {
						$('#finalistas-votacion-status').hide();
					}

					if (!resp.response || !resp.result || resp.result.length === 0) {
						$('#finalistas-empty').show();
						$('#frm-finalistas').modal('show');
						$.unblockUI();
						return;
					}

					var col = $('<div class="col-12"></div>');

					$.each(resp.result, function(i, p) {
						var isChecked = p.es_finalista == 1;
						var activeClass = isChecked ? ' finalista-activo' : '';
						var checkIcon   = isChecked ? '<i class="mdi mdi-check-circle text-white mr-2" style="font-size:1.1rem;"></i>' : '<i class="mdi mdi-circle-outline mr-2" style="font-size:1.1rem;opacity:0.4;"></i>';
						var item = $(
							'<div class="finalista-item d-flex align-items-center p-2 mb-1 rounded' + activeClass + '" style="cursor:pointer;border:1px solid #dee2e6;" data-value="' + escapeHtml(p.invitado_id) + '">' +
								'<input type="checkbox" class="finalista-check" style="display:none;" value="' + escapeHtml(p.invitado_id) + '"' + (isChecked ? ' checked' : '') + '>' +
								'<span class="finalista-icon">' + checkIcon + '</span>' +
								'<span><strong>' + escapeHtml(p.invitado_id) + '</strong>' +
									(p.nombre ? '<br><small class="text-truncate">' + escapeHtml(p.nombre) + '</small>' : '') +
								'</span>' +
							'</div>'
						);
						col.append(item);
					});

					lista.append(col);
					updateFinalistasCounter();
					$('#frm-finalistas').modal('show');
				}, 'json').fail(function() {
					swal({ type: 'warning', title: 'Oops!', text: 'No fue posible cargar los postulados', timer: 4000 });
				}).always(function() {
					$.unblockUI();
				});
			}

			$(document).on('click', '.finalista-item', function() {
				var chk = $(this).find('.finalista-check');
				var willCheck = !chk.prop('checked');
				if (willCheck) {
					var already = $('#finalistas-lista input[type="checkbox"]:checked').length;
					if (already >= 10) {
						swal({ type: 'warning', title: 'Oops!', text: 'Solo puedes seleccionar hasta 10 finalistas', timer: 3000 });
						return;
					}
				}
				chk.prop('checked', willCheck);
				$(this).toggleClass('finalista-activo', willCheck);
				$(this).find('.finalista-icon').html(
					willCheck
						? '<i class="mdi mdi-check-circle text-white mr-2" style="font-size:1.1rem;"></i>'
						: '<i class="mdi mdi-circle-outline mr-2" style="font-size:1.1rem;opacity:0.4;"></i>'
				);
				updateFinalistasCounter();
			});

			$('#btnSaveFinalists').on('click', function() {
				var idEncuesta = $('#finalistas-ID_encuesta').val();
				var idPregunta = $('#finalistas-ID_pregunta').val();
				var invitados  = [];
				$('#finalistas-lista input[type="checkbox"]:checked').each(function() {
					invitados.push($(this).val());
				});

				if (invitados.length === 0) {
					swal({ type: 'warning', title: 'Oops!', text: 'Selecciona al menos un finalista', timer: 3000 });
					return;
				}

				blockPage();
				$.post(
					$apiUrl + 'reporte/finalistas/save/' + idEncuesta + '/' + idPregunta,
					{ invitados: invitados },
					function(resp) {
						if (resp.response) {
							$('#frm-finalistas').modal('hide');
							var votacionExiste = resp.result && resp.result.votacion_existente;
							var idVotacion = (resp.result && resp.result.ID_pregunta_votacion) ? parseInt(resp.result.ID_pregunta_votacion, 10) : 0;
							if (votacionExiste) {
								var folio = idVotacion > 0 ? ' P-' + String(idVotacion).padStart(3, '0') : '';
								swal({ type: 'success', title: '¡Listo!', text: 'Finalistas actualizados. Ya existe una pregunta de votación' + folio, timer: 4500 });
								$('#btnPreview').trigger('click');
								return;
							}

							$('#votacion-ID_encuesta').val(idEncuesta);
							$('#votacion-ID_pregunta_postulacion').val(idPregunta);
							$('#votacion-pregunta').val('');
							$('#votacion-error').hide();
							$('#frm-votacion').modal('show');
						} else {
							swal({ type: 'warning', title: 'Oops!', text: resp.message || 'Error al guardar', timer: 4000 });
						}
					}, 'json'
				).fail(function() {
					swal({ type: 'warning', title: 'Oops!', text: 'Error de comunicación con el servidor', timer: 4000 });
				}).always(function() {
					$.unblockUI();
				});
			});

			$('#frm-votacion').on('shown.bs.modal', function() {
				$('#votacion-pregunta').focus();
			});

			$('#btnCrearPreguntaVotacion').on('click', function() {
				var idEncuesta = $('#votacion-ID_encuesta').val();
				var idPreguntaPost = $('#votacion-ID_pregunta_postulacion').val();
				var textoPregunta = $.trim($('#votacion-pregunta').val());

				if (textoPregunta === '') {
					$('#votacion-error').show();
					return;
				}
				$('#votacion-error').hide();

				blockPage();
				$.post(
					$apiUrl + 'reporte/finalistas/create-votacion/' + idEncuesta + '/' + idPreguntaPost,
					{ pregunta: textoPregunta },
					function(resp) {
						if (resp.response) {
							$('#frm-votacion').modal('hide');
							swal({ type: 'success', title: '¡Listo!', text: 'Pregunta de votación creada correctamente', timer: 3500 });
							$('#btnPreview').trigger('click');
						} else {
							var msg = resp.message || 'No fue posible crear la pregunta';
							if (resp.result && resp.result.already_exists && resp.result.ID_pregunta) {
								msg += ' (P-' + String(resp.result.ID_pregunta).padStart(3, '0') + ')';
							}
							swal({ type: 'warning', title: 'Oops!', text: msg, timer: 4500 });
						}
					}, 'json'
				).fail(function() {
					swal({ type: 'warning', title: 'Oops!', text: 'Error de comunicación con el servidor', timer: 4000 });
